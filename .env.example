# ============================================================
# SUPABASE
# ============================================================
# Encontrás estos valores en: https://supabase.com/dashboard → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx...

# Solo para scripts del lado del servidor (migrations, seed)
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx...

# ============================================================
# AUTH - GOOGLE (fallback recomendado en lugar de Instagram)
# ============================================================
# Crear en: https://console.cloud.google.com → APIs & Services → Credentials
# Configurar también en Supabase → Auth → Providers → Google
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxx

# ============================================================
# AUTH - INSTAGRAM (opcional - requiere Meta Developer App)
# ============================================================
# Ver instrucciones en README.md sección "Instagram OAuth"
# INSTAGRAM_CLIENT_ID=xxxxxxxxxx
# INSTAGRAM_CLIENT_SECRET=xxxxxxxxxx

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# En producción: https://tu-dominio.vercel.app

# ============================================================
# ADMINS
# ============================================================
# Emails separados por coma que tienen acceso admin automático
ADMIN_EMAILS=tu@email.com

# ============================================================
# SUPABASE STORAGE
# ============================================================
# Bucket name para fotos de jugadores (crear en Supabase → Storage)
NEXT_PUBLIC_STORAGE_BUCKET=jugadores
